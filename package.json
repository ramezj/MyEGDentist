{
  "name": "myegdentist",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @myegdentist/api",
    "dev:web": "npm run dev -w @myegdentist/web",
    "build": "npm run db:generate && npm run build -w @myegdentist/api && npm run build -w @myegdentist/web",
    "build:web": "npm run build -w @myegdentist/web",
    "build:api": "npm run db:generate && npm run build -w @myegdentist/api",
    "start:api": "npm run start -w @myegdentist/api",
    "start:web": "npm run start -w @myegdentist/web",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w @myegdentist/api",
    "db:generate": "npm run db:generate -w @myegdentist/api",
    "db:studio": "npm run db:studio -w @myegdentist/api",
    "ui:add": "npx shadcn@latest add -c packages/web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "Monorepo root for MyEGDentist packages."
}
